# --- 🛠️ FOUNDRY & COMPILER ---
# Her forge build sonrası değişen, gereksiz yükler
out/
cache/
foundry.lock
# X-Layer özel derleme çıktıları
artifacts/

# --- 📦 DEPENDENCIES ---
# Kütüphaneler 'lib' altında tutulur, submodule kullanmıyorsan ignore etme. 
# Ama node_modules kesinlikle gitmemeli.
node_modules/
dist/

# --- 🔐 SECRETS & NEURAL KEYS ---
# KRİTİK: Private key ve RPC adreslerini asla commit etme!
.env
.env.*
!.env.example
*.key
*.pem
# AI Sentinel yerel imza logları
secrets/

# --- 📡 BROADCAST & CHAIN DATA ---
# Zincir üstü işlem kayıtları (Sadece son başarılı run'ı tut, gerisini sil)
broadcast/
!broadcast/*/run-latest.json
/broadcast/*/31337/
/broadcast/**/dry-run/
# Yerel node logları
anvil.log

# --- 📊 TESTING & NEURAL REPORTS ---
# Test sonuçları ve Gas analizleri
reports/
coverage/
.lcov
gas-report.txt
.gas-snapshot
# AI Risk analiz raporları
neural-audit-results/

# --- 🚀 UPGRADE & DEPLOYMENT ---
# Scriptlerin geçici dosyaları
upgrade/temp/
*.log

# --- 💻 OS & IDE (PROFESSIONAL) ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ==============================================================================
# 🌊 AOXCAN SECURITY - END OF SPEC
