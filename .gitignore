# Ana dizinde olduğundan emin ol
cd ~/Work/AOXCORE

# Master .gitignore dosyasını AI ve Özel Veri korumasıyla güncelle
cat <<EOF > .gitignore
# ==============================================================================
# 🧠 AOXCORE PROTOCOL | NEURAL & BLOCKCHAIN HYBRID SPEC
# VERSION: 7.0.0 "Sentinel-Shield" - Full Protection
# ==============================================================================

# --- 🤖 AI & MACHINE LEARNING (MUST BE EXCLUDED) ---
# Model ağırlıkları ve devasa veri setleri GitHub'a gitmemeli
**/model_hub/
**/outputs/
**/data/*.jsonl
**/data/*.csv
**/*.safetensors
**/*.onnx
**/*.bin
**/*.pt
**/*.pth

# --- 🧪 TRAINING LOGS & RUNTIME ---
**/runs/
**/checkpoint-*/
**/__pycache__/
**/*.pyc
.ipynb_checkpoints/

# --- 🛠️ FOUNDRY & SMART CONTRACTS ---
/out/
/cache/
/artifacts/
foundry.lock
/lib/

# --- 📦 DEPENDENCIES & WEB ---
node_modules/
dist/
build/
.vite/
.yarn/
!.yarn/patches/
!.yarn/releases/

# --- 🔐 SECRETS & NEURAL KEYS (CRITICAL) ---
.env
.env.*
!.env.example
*.key
*.pem
*.json.gpg
secrets/
.secret*
**/config_private.py

# --- 📡 BLOCKCHAIN & SENTINEL DATA ---
broadcast/
!broadcast/*/run-latest.json
/broadcast/*/31337/
/broadcast/**/dry-run/
anvil.log
*.trace

# --- 📊 AUDIT & NEURAL REPORTS ---
reports/
coverage/
*.lcov
gas-report.txt
.gas-snapshot
neural-audit-results/

# --- 💻 OS & IDE ---
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.bak
*.tmp
*.temp
EOF

echo "🛡️ Sentinel-Shield .gitignore (AI + Blockchain) aktif edildi."
