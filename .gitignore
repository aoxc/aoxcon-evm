# --- 🛠️ FOUNDRY & COMPILER (ROOT SPECIFIC) ---
# Sadece ana dizindeki (root) derleme çıktılarını engeller.
/out/
/cache/
/artifacts/
foundry.lock

# --- 📦 DEPENDENCIES & LIBRARIES (SURGICAL PRECISION) ---
# KRİTİK: Genel "lib/" yasağı kaldırıldı. 
# Sadece kök dizindeki kütüphaneleri (Submodules/Foundry) engeller.
/lib/
node_modules/
dist/
build/
.vite/
.yarn/
!.yarn/patches/
!.yarn/releases/

# --- 🔐 SECRETS & NEURAL KEYS (ZERO TRUST) ---
# .env dosyalarını ve anahtarları asla sızdırmaz.
.env
.env.*
!.env.example
*.key
*.pem
*.json.gpg
secrets/
.secret*

# --- 📡 BLOCKCHAIN & SENTINEL DATA ---
# Yayın kayıtları (Broadcast) temizliği
broadcast/
!broadcast/*/run-latest.json
/broadcast/*/31337/
/broadcast/**/dry-run/
anvil.log
*.trace

# --- 📊 AUDIT & NEURAL REPORTS ---
reports/
coverage/
*.lcov
gas-report.txt
.gas-snapshot
neural-audit-results/

# --- 🚀 RUNTIME & LOGS ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
panic.log

# --- 💻 OS & IDE (PROFESSIONAL CLEANUP) ---
