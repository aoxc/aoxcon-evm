[submodule "lib/forge-std"]
    # 🛠️ Testing Framework: The industrial engine for verification.
	path = lib/forge-std
	url = https://github.com/foundry-rs/forge-std
    branch = master

[submodule "lib/openzeppelin-contracts"]
	# 🛡️ Secure Contracts: Base layer for the Sovereign Fleet.
	path = lib/openzeppelin-contracts
	url = https://github.com/openzeppelin/openzeppelin-contracts
    branch = v5.0.0

[submodule "lib/openzeppelin-contracts-upgradeable"]
	# 🧬 Evolution Layer: Upgradeable logic for Neural Core.
	path = lib/openzeppelin-contracts-upgradeable
	url = https://github.com/openzeppelin/openzeppelin-contracts-upgradeable
    branch = v5.0.0

[submodule "lib/openzeppelin-foundry-upgrades"]
	# 🚀 Deployment Engine: Safe upgrade management for Foundry.
	path = lib/openzeppelin-foundry-upgrades
	url = https://github.com/OpenZeppelin/openzeppelin-foundry-upgrades
